# Copie este arquivo para backend/.env e preencha os valores.
# cp .env.example backend/.env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=smv
DATABASE_URL=postgresql://postgres:SUA_SENHA@postgres:5432/smv

# Redis (fila de jobs de análise)
REDIS_URL=redis://redis:6379/0

# Análise de imagens (worker + Roboflow)
DETECTOR_DEFEITOS=yolo
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=rdd2022-22jrg/1
ROBOFLOW_API_URL=https://serverless.roboflow.com
YOLO_CONF_THRESHOLD=0.40
YOLO_IOU_THRESHOLD=0.45

# MinIO (armazenamento de fotos)
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=smp-fotos
MINIO_USE_SSL=false

# Autenticação JWT
SECRET_KEY_JWT=
ALGORITHM=HS256

# Aplicação
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# E-mail (opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# CREA (opcional)
CREA_API_KEY=
CREA_API_URL=https://www.consultacrea.com.br/api/index.php
